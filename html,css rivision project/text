:root {
  --cyan: #29b6d8;
  --border: #eee;
}
*,
*::before,
*::after {
  box-sizing: border-box;
}
body {
  font-family: "Nunito", sans-serif;
}
a {
  text-decoration: none;
}
ul {
  list-style: none;
}

#header {
  background: #fff;
}
.header-top {
  border-bottom: 1px solid var(--border);
}
.header-top strong {
  font-size: 13px;
  font-weight: 800;
  color: #222;
}
.header-top a,
.header-top span {
  font-size: 12.5px;
  color: #666;
  transition: color 0.2s;
}
.header-top a:hover {
  color: var(--cyan);
}

.contact-icon {
  width: 40px;
  height: 40px;
  border: 2px solid var(--cyan);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--cyan);
  font-size: 15px;
  transition:
    background 0.25s,
    color 0.25s;
  flex-shrink: 0;
}
.contact-icon:hover {
  background: var(--cyan);
  color: #fff;
}

.logo-wrap {
  position: relative;
}

